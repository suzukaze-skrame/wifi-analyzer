    "NSLocationUsageDescription" : {
      "comment" : "Privacy - Location Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wi-Fi Analyzer uses location permission so macOS can expose nearby Wi-Fi SSID and BSSID details."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
