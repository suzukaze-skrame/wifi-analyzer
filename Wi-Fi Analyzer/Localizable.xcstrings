    "empty.location_needed.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allow Location Services for this app so macOS can expose SSID and BSSID details."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请允许此 App 使用定位服务，以便 macOS 提供 SSID 和 BSSID 详情。"
          }
        }
      }
    },
    "empty.location_settings.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable Location Services for Wi-Fi Analyzer in System Settings, then return here and refresh."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在系统设置中为 Wi-Fi Analyzer 开启定位服务，然后回到这里刷新。"
          }
        }
      }
    },
    "empty.no_networks.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
